# CTA Real-Time Alerts API
# Register at: https://www.transitchicago.com/developers/traintracker.aspx
CTA_API_KEY=your_cta_api_key_here

# OpenWeatherMap API (free tier works)
# Register at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Hugging Face token (needed to pull gated Llama 3.1 weights)
# Get at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Model paths (defaults shown — override to use custom locations)
ATTENTION_MODEL_PATH=models/transit_attention.pt
LLAMA_ADAPTER_PATH=models/llama_cta_adapter
BASE_MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct
